# ── OpenCrawl (Crawl4AI) - FREE self-hosted ──────────────────────────────────
# Docker se run karo: docker run -p 11235:11235 unclecode/crawl4ai:latest
# Ya pip se: pip install crawl4ai && crawl4ai-run
OPENCRAWL_API_URL=http://localhost:11235
OPENCRAWL_API_KEY=

# ── Browser / Playwright ──────────────────────────────────────────────────────
BROWSER_DRIVER=openclaw
BROWSER_DRIVER_FALLBACK=1
OPENCLAW_DISABLED=0

# ── Blog Comment Settings ─────────────────────────────────────────────────────
BLOG_COMMENT_ADAPTIVE_MODE=1
BLOG_COMMENT_STRICT_MODE=0
BLOG_COMMENT_TYPING_DELAY_MS=40-120
BLOG_COMMENT_SCROLL_BEFORE_TYPE=1

# ── Rate Limiting ─────────────────────────────────────────────────────────────
MIN_DELAY_MINUTES=1
MAX_DELAY_MINUTES=3

# ── Approval Mode: cli | ui | auto ────────────────────────────────────────────
APPROVAL_MODE=cli
